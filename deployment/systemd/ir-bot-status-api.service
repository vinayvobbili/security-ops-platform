[Unit]
Description=IR Bot Status API
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/vinay/security-ops-platform
ExecStart=/home/vinay/security-ops-platform/.venv/bin/python3 deployment/bot_status_api.py
Restart=on-failure
KillMode=mixed
TimeoutStopSec=10
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
