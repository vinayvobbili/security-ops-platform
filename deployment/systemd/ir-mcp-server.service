[Unit]
Description=IR Unified MCP Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/vinay/security-ops-platform
ExecStart=/home/vinay/security-ops-platform/.venv/bin/python -m mcp_server
Restart=on-failure
KillMode=mixed
TimeoutStopSec=10
RestartSec=10
Environment=PYTHONPATH=/home/vinay/security-ops-platform

[Install]
WantedBy=default.target
