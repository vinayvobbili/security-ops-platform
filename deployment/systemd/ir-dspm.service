[Unit]
Description=DSPM Sidecar (containerized) — serves DSPM UI at :8033
After=network.target
# docker.service is a system-level unit; user-level systemd can't Requires= it,
# but docker is enabled at boot so it's always up by the time user services start.

[Service]
Type=simple
Restart=on-failure
RestartSec=10
TimeoutStartSec=60
TimeoutStopSec=20

ExecStartPre=-/usr/bin/docker stop ir-dspm
ExecStartPre=-/usr/bin/docker rm ir-dspm

# Run the current image. The :current tag is updated by the deploy portal on
# activate/rollback. Container is read-only except for /app/backup (bind mount
# for persistent state) and tmpfs for /tmp and /run. Only 127.0.0.1 is exposed —
# external access is via the Flask reverse proxy at /dspm-app/*.
ExecStart=/usr/bin/docker run --rm --name ir-dspm \
  -p 127.0.0.1:8033:8000 \
  --user 1001:1001 \
  --read-only \
  --tmpfs /tmp:rw,size=64M \
  --tmpfs /run:rw,size=16M \
  --memory=1g --cpus=1.0 --pids-limit=128 \
  --security-opt no-new-privileges \
  --cap-drop=ALL \
  --add-host=host.docker.internal:host-gateway \
  -e AZURE_OPENAI_ENDPOINT=http://host.docker.internal:8011 \
  -e AZURE_OPENAI_KEY=dummy \
  -e AZURE_OPENAI_DEPLOYMENT=local-llm \
  -e AZURE_OPENAI_API_VERSION=2024-08-01-preview \
  -v /home/vinay/security-ops-platform/external/dspm/backup:/app/backup \
  ir-dspm:current

ExecStop=/usr/bin/docker stop ir-dspm

[Install]
WantedBy=default.target
