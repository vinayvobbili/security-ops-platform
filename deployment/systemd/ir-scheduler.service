[Unit]
Description=IR Scheduler
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/vinay/security-ops-platform
ExecStart=/home/vinay/security-ops-platform/.venv/bin/python3 -u src/ir_scheduler.py
Restart=on-failure
KillMode=mixed
TimeoutStopSec=10
RestartSec=30
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
